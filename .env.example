# Google OAuth token — provide either JSON content or a file path
# GOOGLE_TOKEN_JSON={"token": "...", "refresh_token": "..."}
# GOOGLE_TOKEN_PATH=/app/token.json

# Google OAuth credentials — provide either JSON content or a file path
# GOOGLE_CREDENTIALS_JSON={"installed": {"client_id": "...", ...}}
# GOOGLE_CREDENTIALS_PATH=/app/credentials.json

# MFC calendar URL to sync from
MFC_CALENDAR_URL=https://share.myfreecams.com/RinCity/calendar

# Google Calendar ID to sync into (use "primary" for the default calendar)
GOOGLE_CALENDAR_ID=primary

# Sync window
# SYNC_START_DATE=2024-01-01
SYNC_MONTHS=2

# Run continuously with this interval between syncs (e.g. "30m", "12h", "1d")
# Omit to run once and exit
# SLEEP_INTERVAL=12h

# SMTP email notifications (all optional — omit to disable email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
SMTP_TO=you@example.com
SMTP_USE_STARTTLS=true
SMTP_SUBJECT_PREFIX=RinCity Calendar Sync

# Notification triggers
NOTIFY_ON_SUCCESS=false
NOTIFY_ON_CHANGES=true
NOTIFY_ON_ERROR=true

# Set to true to preview changes without writing to Google Calendar
DRY_RUN=false

# Optional: write email preview to this HTML file instead of sending
# PREVIEW_EMAIL_HTML_PATH=/tmp/preview.html
